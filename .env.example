# PostgreSQL
DATABASE_URL="postgresql://recon:recon@localhost:5432/recon?schema=public"

# Redis (BullMQ)
REDIS_URL="redis://127.0.0.1:6379"

# App crypto (32 bytes, base64) — required for storing API keys encrypted at rest
# Generate (Linux/macOS):
#   openssl rand -base64 32
APP_ENCRYPTION_KEY="REPLACE_ME_BASE64_32_BYTES"

# Base path — set if running behind a reverse proxy at a sub-path (e.g. /scoptix)
# Leave empty or omit for root path (/). Changing this requires a rebuild.
NEXT_PUBLIC_BASE_PATH="/your-base-path"

# Optional: seed a VirusTotal key during `npm run db:seed` (dev only)
# VT_SEED_API_KEY=""
