{
  "name": "scoptix",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "postinstall": "prisma generate",
    "setup": "npm run db:migrate && npm run db:seed",
    "db:migrate": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:seed": "prisma db seed",
    "worker": "tsx workers/scan-worker.ts",
    "dev:all": "concurrently \"npm run dev\" \"npm run worker\"",
    "dev:local": "bash scripts/dev-local.sh",
    "docker:infra": "docker compose up -d postgres redis",
    "docker:wait": "bash scripts/wait-for-infra.sh",
    "docker:infra:setup": "npm run docker:infra && npm run docker:wait && npm run setup",
    "docker:up": "docker compose --profile full up -d --build",
    "docker:down": "bash docker-stop.sh",
    "docker:logs": "docker compose --profile full logs -f"
  },
  "dependencies": {
    "@prisma/client": "^6.5.0",
    "axios": "1.14.0",
    "bullmq": "^5.47.2",
    "ioredis": "^5.6.0",
    "next": "^15.2.4",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "socks-proxy-agent": "^8.0.5",
    "tldts": "^7.0.6",
    "wappalyzer-core": "^6.10.66",
    "zod": "^3.24.2"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.1.2",
    "dotenv": "^16.4.7",
    "eslint": "^9.24.0",
    "eslint-config-next": "^15.2.4",
    "postcss": "^8.5.8",
    "prisma": "^6.5.0",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3"
  }
}
